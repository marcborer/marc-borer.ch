---
import PageLayout from '../../layouts/PageLayout.astro';
import Timeline from '../../components/Timeline.astro';
import experience from '../../data/experience.en.json';
---

<PageLayout title="Experience — Marc Borer" description="Professional journey of Marc Borer — from systems engineering through IT operations to enterprise architecture.">
  <section class="experience-page">
    <h1 class="page-heading" data-animate="slide-up">Experience</h1>
    <p class="page-intro" data-animate="slide-up" data-delay="100">
      My professional journey — from systems engineering fundamentals through IT operations management
      to enterprise architecture ownership and infrastructure modernization.
    </p>

    <a
      href="https://github.com/marcborer/cv/releases/latest/download/Lebenslauf.pdf"
      class="btn btn-primary"
      data-animate="slide-up" data-delay="200"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
        <polyline points="7 10 12 15 17 10" />
        <line x1="12" y1="15" x2="12" y2="3" />
      </svg>
      Download CV
    </a>

    <div class="timeline-wrapper" data-animate="slide-up" data-delay="300">
      <Timeline entries={experience} />
    </div>
  </section>
</PageLayout>

<style>
  .experience-page {
    padding: var(--space-16) 0;
  }

  .page-heading {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-6);
  }

  .page-intro {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 50rem;
    margin-bottom: var(--space-8);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-8);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
    cursor: pointer;
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: var(--slate-950);
    border: 1px solid var(--color-accent);
  }

  .btn-primary:hover {
    background-color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: var(--slate-950);
    transform: translateY(-1px);
  }

  .btn svg {
    flex-shrink: 0;
  }

  .timeline-wrapper {
    margin-top: var(--space-16);
  }

  @media (max-width: 768px) {
    .page-heading {
      font-size: var(--text-3xl);
    }
  }
</style>
