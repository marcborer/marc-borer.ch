---
import PageLayout from '../layouts/PageLayout.astro';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

const lang = (Astro.currentLocale || 'de') as Lang;
const t = useTranslations(lang);
---

<PageLayout title="Kontakt — Marc Borer" description="Kontaktieren Sie Marc Borer für Zusammenarbeit im Bereich Enterprise-Infrastruktur, Cloud-Architektur oder Automatisierung.">
  <section class="contact">
    <h1 class="contact-heading" data-animate="slide-up">{t('contact.title')}</h1>
    <p class="contact-intro" data-animate="slide-up" data-delay="100">
      {t('contact.intro')}
    </p>

    <div class="contact-grid">
      <!-- Email — primary CTA -->
      <a href="mailto:mb@marc-borer.ch" class="contact-card contact-card--primary" data-animate="slide-up" data-delay="200">
        <svg class="contact-icon" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="M22 4L12 13L2 4" />
        </svg>
        <span class="contact-label">Email</span>
        <span class="contact-value">mb@marc-borer.ch</span>
      </a>

      <!-- GitHub -->
      <a href="https://github.com/marcborer" class="contact-card" data-animate="slide-up" data-delay="300" target="_blank" rel="noopener noreferrer">
        <svg class="contact-icon" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span class="contact-label">GitHub</span>
        <span class="contact-value">github.com/marcborer</span>
      </a>

      <!-- LinkedIn -->
      <a href="https://linkedin.com/in/marc-b-6780ab5a/" class="contact-card" data-animate="slide-up" data-delay="400" target="_blank" rel="noopener noreferrer">
        <svg class="contact-icon" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <span class="contact-label">LinkedIn</span>
        <span class="contact-value">LinkedIn</span>
      </a>
    </div>
  </section>
</PageLayout>

<style>
  .contact {
    padding: var(--space-16) 0;
  }

  .contact-heading {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-6);
  }

  .contact-intro {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 50rem;
    margin-bottom: var(--space-12);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .contact-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-10) var(--space-6);
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    text-align: center;
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .contact-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.15);
  }

  .contact-card--primary {
    border-color: var(--color-accent);
    border-width: 2px;
  }

  .contact-card--primary .contact-icon {
    color: var(--color-accent);
  }

  .contact-icon {
    color: var(--color-text-secondary);
    transition: color 0.2s ease;
  }

  .contact-card:hover .contact-icon {
    color: var(--color-accent);
  }

  .contact-label {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text-heading);
  }

  .contact-value {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    word-break: break-all;
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
