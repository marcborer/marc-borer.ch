---
import { getLangFromUrl, getLocalePath } from '../i18n/utils';

interface NavChild {
  label: string;
  href: string;
}

interface NavItem {
  label: string;
  href?: string;
  children?: NavChild[];
}

interface Props {
  title: string;
  items: NavItem[];
}

const { title, items } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname.replace(/\/$/, '');

function localize(href: string): string {
  return getLocalePath(href, lang);
}

function isActive(href: string): boolean {
  return currentPath === localize(href);
}
---

<aside class="doc-sidebar">
  <nav class="doc-nav" aria-label="Documentation">
    <div class="doc-nav-title">{title}</div>
    <ul class="doc-nav-list">
      {items.map((item) =>
        'children' in item && item.children ? (
          <li class="doc-nav-group">
            <span class="doc-nav-group-label">{item.label}</span>
            <ul class="doc-nav-sublist">
              {item.children.map((child) => (
                <li>
                  <a
                    href={`${localize(child.href)}/`}
                    class:list={['doc-nav-link', 'doc-nav-sublink', { active: isActive(child.href) }]}
                    aria-current={isActive(child.href) ? 'page' : undefined}
                  >
                    {child.label}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        ) : (
          <li>
            <a
              href={`${localize(item.href!)}/`}
              class:list={['doc-nav-link', { active: isActive(item.href!) }]}
              aria-current={isActive(item.href!) ? 'page' : undefined}
            >
              {item.label}
            </a>
          </li>
        )
      )}
    </ul>
  </nav>
</aside>

<style>
  .doc-sidebar {
    position: sticky;
    top: var(--space-8);
    align-self: start;
  }

  .doc-nav-title {
    font-family: 'Syne', ui-sans-serif, system-ui, sans-serif;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-heading);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding-bottom: var(--space-4);
    margin-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .doc-nav-list {
    list-style: none;
    padding: 0;
  }

  .doc-nav-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    border-left: 3px solid transparent;
    transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
  }

  @media (hover: hover) {
    .doc-nav-link:hover {
      color: var(--color-text-heading);
      background-color: var(--color-accent-subtle);
    }
  }

  .doc-nav-link.active {
    color: var(--color-accent);
    background-color: var(--color-accent-subtle);
    border-left-color: var(--color-accent);
  }

  .doc-nav-group {
    margin-top: var(--space-3);
  }

  .doc-nav-group-label {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .doc-nav-sublist {
    list-style: none;
    padding: 0;
  }

  .doc-nav-sublink {
    padding-left: var(--space-6);
  }

  @media (max-width: 768px) {
    .doc-sidebar {
      position: static;
      border-bottom: 1px solid var(--color-border);
      padding-bottom: var(--space-4);
      margin-bottom: var(--space-6);
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .doc-nav-title {
      display: none;
    }

    .doc-nav-list {
      display: flex;
      gap: var(--space-1);
      white-space: nowrap;
      flex-wrap: nowrap;
    }

    .doc-nav-group {
      display: flex;
      align-items: center;
      gap: var(--space-1);
      margin-top: 0;
    }

    .doc-nav-group-label {
      padding: var(--space-2) var(--space-2);
      font-size: var(--text-xs);
      color: var(--color-text-secondary);
    }

    .doc-nav-sublist {
      display: flex;
      gap: var(--space-1);
    }

    .doc-nav-link {
      padding: var(--space-1) var(--space-3);
      border-radius: var(--radius-full);
      font-size: var(--text-xs);
      border-left: none;
    }

    .doc-nav-link.active {
      border-left: none;
    }

    .doc-nav-sublink {
      padding-left: var(--space-3);
    }
  }
</style>
