---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = (Astro.currentLocale || 'de') as Lang;
const t = useTranslations(lang);
---

<section class="hero">
  <!-- Dot grid background -->
  <div class="hero-grid"></div>
  <!-- Single accent glow -->
  <div class="hero-glow"></div>
  <!-- Noise grain overlay -->
  <div class="hero-grain"></div>

  <div class="hero-layout">
    <!-- Left: Text content -->
    <div class="hero-content">
      <span class="hero-role">{t('hero.role')}</span>
      <h1 class="hero-name">Marc Borer</h1>
      <p class="hero-tagline">{t('hero.tagline')}</p>
      <p class="hero-keywords">{t('hero.keywords')}</p>
      <div class="hero-cta">
        <a href={getRelativeLocaleUrl(lang, '/projects/')} class="btn btn-primary">
          {t('hero.cta.projects')}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
        <a
          href="https://github.com/marcborer/cv/releases/latest/download/Lebenslauf.pdf"
          class="btn btn-ghost"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
          {t('hero.cta.cv')}
        </a>
      </div>
    </div>

    <!-- Right: Terminal visual -->
    <div class="hero-terminal">
      <div class="terminal-chrome">
        <span class="terminal-dot"></span>
        <span class="terminal-dot"></span>
        <span class="terminal-dot"></span>
        <span class="terminal-title">terminal</span>
      </div>
      <pre class="terminal-body"><code><span class="t-prompt">$</span> <span class="t-cmd">whoami</span>
<span class="t-output">marc-borer | {t('hero.terminal.whoami')}</span>

<span class="t-prompt">$</span> <span class="t-cmd">stack --list</span>
<span class="t-output">  {t('hero.terminal.stack')}</span>

<span class="t-prompt">$</span> <span class="t-cmd">uptime</span>
<span class="t-output">10+ years in enterprise IT</span>

<span class="t-prompt">$</span> <span class="t-cursor">_</span></code></pre>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: center;
    padding: var(--space-16) 0;
    overflow: hidden;
  }

  /* ---- Dot grid background ---- */
  .hero-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(34, 211, 238, 0.12) 1px, transparent 1px);
    background-size: 28px 28px;
    mask-image: radial-gradient(ellipse 60% 70% at 75% 50%, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 60% 70% at 75% 50%, black 20%, transparent 70%);
    pointer-events: none;
  }

  /* ---- Single accent glow ---- */
  .hero-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 70% 30%,
      rgba(34, 211, 238, 0.1) 0%,
      transparent 55%
    );
    pointer-events: none;
  }

  /* ---- Grain texture ---- */
  .hero-grain {
    position: absolute;
    inset: 0;
    opacity: 0.025;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    pointer-events: none;
  }

  /* ---- Layout: asymmetric split ---- */
  .hero-layout {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
    width: 100%;
  }

  /* ---- Text content ---- */
  .hero-content {
    position: relative;
  }

  .hero-role {
    display: inline-block;
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', monospace;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-accent);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-6);
  }

  .hero-name {
    font-family: 'Syne', ui-sans-serif, system-ui, sans-serif;
    font-size: clamp(2.5rem, 4vw + 1rem, 4rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-4);
  }

  .hero-tagline {
    font-size: var(--text-lg);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .hero-keywords {
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', monospace;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
    margin-bottom: var(--space-8);
    opacity: 0.7;
  }

  .hero-cta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  /* ---- Buttons ---- */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: all 0.2s ease;
    cursor: pointer;
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: var(--slate-950);
    border: 1px solid var(--color-accent);
  }

  .btn-primary:hover {
    background-color: var(--color-accent-hover);
    border-color: var(--color-accent-hover);
    color: var(--slate-950);
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(34, 211, 238, 0.3);
  }

  .btn-ghost {
    background-color: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
  }

  .btn-ghost:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-1px);
  }

  /* ---- Terminal visual ---- */
  .hero-terminal {
    position: relative;
    background: rgba(15, 23, 42, 0.6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    backdrop-filter: blur(10px);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    transform: perspective(800px) rotateY(-2deg) rotateX(1deg);
  }

  .terminal-chrome {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: var(--space-3) var(--space-4);
    background: rgba(30, 41, 59, 0.8);
    border-bottom: 1px solid var(--color-border);
  }

  .terminal-dot {
    width: 10px;
    height: 10px;
    border-radius: var(--radius-full);
    background: var(--color-border);
  }

  .terminal-dot:nth-child(1) { background: #ff5f57; }
  .terminal-dot:nth-child(2) { background: #ffbd2e; }
  .terminal-dot:nth-child(3) { background: #28c840; }

  .terminal-title {
    margin-left: auto;
    font-family: 'SF Mono', 'Fira Code', monospace;
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    opacity: 0.5;
  }

  .terminal-body {
    padding: var(--space-5);
    margin: 0;
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', monospace;
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--color-text-primary);
    overflow-x: auto;
    white-space: pre;
  }

  .terminal-body code {
    font-family: inherit;
    font-size: inherit;
  }

  .t-prompt {
    color: var(--color-accent);
    font-weight: 700;
  }

  .t-cmd {
    color: var(--color-text-heading);
  }

  .t-output {
    color: var(--color-text-secondary);
  }

  .t-cursor {
    color: var(--color-accent);
  }

  /* Light mode terminal adjustments */
  [data-theme="light"] .hero-terminal {
    background: rgba(248, 250, 252, 0.8);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
  }

  [data-theme="light"] .terminal-chrome {
    background: rgba(226, 232, 240, 0.8);
  }

  /* ---- Animations ---- */
  .hero-role, .hero-name, .hero-tagline, .hero-keywords, .hero-cta, .hero-terminal {
    opacity: 1;
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-role {
      opacity: 0;
      animation: hero-fade 0.5s ease both 0.05s;
    }
    .hero-name {
      opacity: 0;
      animation: hero-up 0.5s ease both 0.15s;
    }
    .hero-tagline {
      opacity: 0;
      animation: hero-fade 0.5s ease both 0.3s;
    }
    .hero-keywords {
      opacity: 0;
      animation: hero-fade 0.5s ease both 0.4s;
    }
    .hero-cta {
      opacity: 0;
      animation: hero-up 0.5s ease both 0.5s;
    }
    .hero-terminal {
      opacity: 0;
      animation: hero-terminal-in 0.7s ease both 0.4s;
    }

    .t-cursor {
      animation: cursor-blink 1s step-end infinite;
    }

    @keyframes hero-fade {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes hero-up {
      from { opacity: 0; transform: translateY(16px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes hero-terminal-in {
      from { opacity: 0; transform: perspective(800px) rotateY(-5deg) rotateX(2deg) translateX(20px); }
      to { opacity: 1; transform: perspective(800px) rotateY(-2deg) rotateX(1deg) translateX(0); }
    }
    @keyframes cursor-blink {
      50% { opacity: 0; }
    }
  }

  /* ---- Mobile ---- */
  @media (max-width: 768px) {
    .hero {
      min-height: auto;
      padding: var(--space-12) 0;
    }

    .hero-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .hero-name {
      font-size: clamp(2rem, 8vw, 3rem);
    }

    .hero-terminal {
      transform: none;
    }

    .hero-cta {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      justify-content: center;
    }

    .hero-grid {
      mask-image: radial-gradient(ellipse 80% 50% at 50% 100%, black 10%, transparent 60%);
      -webkit-mask-image: radial-gradient(ellipse 80% 50% at 50% 100%, black 10%, transparent 60%);
    }
  }
</style>
