---
import { languages } from '../i18n/ui';
import { getTranslatedPath } from '../i18n/utils';
import type { Lang } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const siteUrl = 'https://marc-borer.ch';

// Get the current path relative to the locale prefix
const currentLocale = (Astro.currentLocale || 'de') as Lang;
const currentPath = Astro.url.pathname;

// Strip the locale prefix to get the base path
let basePath = currentPath;
if (currentLocale !== 'de' && currentPath.startsWith(`/${currentLocale}`)) {
  basePath = currentPath.slice(`/${currentLocale}`.length) || '/';
}
---

{Object.keys(languages).map((lang) => {
  const translatedPath = getTranslatedPath(basePath, currentLocale, lang as Lang);
  return (
    <link
      rel="alternate"
      hreflang={lang}
      href={`${siteUrl}${getRelativeLocaleUrl(lang, translatedPath)}`}
    />
  );
})}
<link rel="alternate" hreflang="x-default" href={`${siteUrl}${getRelativeLocaleUrl('de', basePath)}`} />
