---
// CI/CD: Pipeline flow from Git → Bamboo → Ansible → Multi-target deployment
// Component layer showing the multi-tier stack
---

<div class="diagram-container" data-animate="slide-up">
  <svg viewBox="0 0 800 420" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="CI/CD Pipeline Architecture Diagram">
    <!-- Pipeline label -->
    <text x="400" y="30" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11" font-weight="600" letter-spacing="0.1em">DEPLOYMENT PIPELINE</text>

    <!-- Pipeline nodes -->
    <!-- Source -->
    <rect x="30" y="55" width="140" height="56" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="100" y="78" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">SOURCE</text>
    <text x="100" y="96" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Git Repository</text>

    <!-- Arrow -->
    <line x1="170" y1="83" x2="210" y2="83" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.6"/>
    <polygon points="210,78 220,83 210,88" fill="var(--color-accent)" opacity="0.6"/>

    <!-- CI -->
    <rect x="220" y="55" width="140" height="56" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="290" y="78" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">CI SERVER</text>
    <text x="290" y="96" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Bamboo</text>

    <!-- Arrow -->
    <line x1="360" y1="83" x2="400" y2="83" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.6"/>
    <polygon points="400,78 410,83 400,88" fill="var(--color-accent)" opacity="0.6"/>

    <!-- IaC -->
    <rect x="410" y="55" width="160" height="56" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="490" y="78" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">INFRASTRUCTURE AS CODE</text>
    <text x="490" y="96" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Ansible Roles</text>

    <!-- Fan-out arrows to targets (lines end at box left edge, y = box vertical center) -->
    <line x1="570" y1="72" x2="640" y2="56" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4"/>
    <line x1="570" y1="83" x2="640" y2="96" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4"/>
    <line x1="570" y1="94" x2="640" y2="136" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4"/>

    <!-- Deployment targets -->
    <rect x="640" y="40" width="140" height="32" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="710" y="61" text-anchor="middle" fill="var(--color-text-primary)" font-size="11">Azure Cloud</text>

    <rect x="640" y="80" width="140" height="32" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="710" y="101" text-anchor="middle" fill="var(--color-text-primary)" font-size="11">Hyper-V Cluster</text>

    <rect x="640" y="120" width="140" height="32" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="710" y="141" text-anchor="middle" fill="var(--color-text-primary)" font-size="11">On-Premises</text>

    <!-- Separator -->
    <line x1="40" y1="185" x2="760" y2="185" stroke="var(--color-border)" stroke-width="1" opacity="0.4"/>
    <text x="400" y="210" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11" font-weight="600" letter-spacing="0.1em">COMPONENT ARCHITECTURE</text>

    <!-- Component layer - multi-tier stack -->
    <!-- Load Balancer -->
    <rect x="280" y="235" width="240" height="44" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="400" y="262" text-anchor="middle" fill="var(--color-text-primary)" font-size="12" font-weight="500">HAProxy Load Balancer</text>

    <!-- Arrow down -->
    <line x1="400" y1="279" x2="400" y2="300" stroke="var(--color-border)" stroke-width="1" opacity="0.5"/>

    <!-- Application tier -->
    <rect x="180" y="300" width="140" height="44" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="250" y="320" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">APPLICATION</text>
    <text x="250" y="336" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">DAM Platform</text>

    <rect x="340" y="300" width="120" height="44" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="400" y="326" text-anchor="middle" fill="var(--color-text-primary)" font-size="11">Rendering</text>

    <rect x="480" y="300" width="140" height="44" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="550" y="326" text-anchor="middle" fill="var(--color-text-primary)" font-size="11">Monitoring</text>

    <!-- Data tier -->
    <rect x="120" y="370" width="130" height="36" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="185" y="393" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Elasticsearch</text>

    <rect x="268" y="370" width="100" height="36" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="318" y="393" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Redis</text>

    <rect x="386" y="370" width="120" height="36" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="446" y="393" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">RabbitMQ</text>

    <rect x="524" y="370" width="150" height="36" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="599" y="393" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Graphite / Grafana</text>
  </svg>
</div>

<style>
  .diagram-container {
    max-width: 50rem;
    margin: var(--space-8) auto;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-primary);
  }

  .diagram-container svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .diagram-container svg text {
    font-family: 'DM Sans', ui-sans-serif, system-ui, sans-serif;
  }
</style>
