---
// SmallCapTrader: Vertical data flow showing the trading pipeline
// Market Data → Ingestion → Strategy Engine → Execution
// Branch to Rule Mining, data stores as shared layer, dual-mode split
---

<div class="diagram-container" data-animate="slide-up">
  <svg viewBox="0 0 800 540" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="SmallCapTrader Architecture Diagram">
    <!-- Market Data Input -->
    <rect x="280" y="20" width="240" height="44" rx="8" fill="none" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4 3"/>
    <text x="400" y="47" text-anchor="middle" fill="var(--color-text-secondary)" font-size="12">Market Data Feeds (WebSocket)</text>

    <!-- Arrow -->
    <line x1="400" y1="64" x2="400" y2="85" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.5"/>
    <polygon points="395,85 400,95 405,85" fill="var(--color-accent)" opacity="0.5"/>

    <!-- Ingestion Layer -->
    <rect x="260" y="95" width="280" height="50" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="400" y="117" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">INGESTION LAYER</text>
    <text x="400" y="135" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Real-time Streaming · Symbol Scanner</text>

    <!-- Arrow -->
    <line x1="400" y1="145" x2="400" y2="170" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.5"/>
    <polygon points="395,170 400,180 405,170" fill="var(--color-accent)" opacity="0.5"/>

    <!-- Strategy Engine -->
    <rect x="240" y="180" width="320" height="55" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="400" y="203" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">STRATEGY ENGINE</text>
    <text x="400" y="222" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Multiple Strategies · Signal Arbitration · Backtesting</text>

    <!-- Branch: left to Rule Mining, right to Execution -->
    <!-- Arrow down to Execution -->
    <line x1="400" y1="235" x2="400" y2="365" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.5"/>
    <polygon points="395,365 400,375 405,365" fill="var(--color-accent)" opacity="0.5"/>

    <!-- Arrow to Rule Mining -->
    <line x1="320" y1="235" x2="160" y2="270" stroke="var(--color-border)" stroke-width="1.5" opacity="0.4"/>

    <!-- Rule Mining Engine -->
    <rect x="40" y="260" width="220" height="55" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="150" y="283" text-anchor="middle" fill="var(--color-text-primary)" font-size="10" font-weight="600">RULE MINING ENGINE</text>
    <text x="150" y="302" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Beam Search · Auto-Promotion</text>

    <!-- Arrow back from Rule Mining to Strategy -->
    <line x1="200" y1="260" x2="320" y2="225" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4 3" opacity="0.3"/>

    <!-- Execution Layer -->
    <rect x="260" y="375" width="280" height="50" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="400" y="397" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">EXECUTION LAYER</text>
    <text x="400" y="415" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Alpaca · Interactive Brokers</text>

    <!-- Dual-mode boundary -->
    <rect x="595" y="160" width="175" height="140" rx="8" fill="none" stroke="var(--color-accent)" stroke-width="1" stroke-dasharray="6 4" opacity="0.4"/>
    <text x="682" y="183" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600" opacity="0.7">DUAL MODE</text>

    <rect x="610" y="195" width="145" height="34" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="682" y="217" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Monolithic</text>

    <rect x="610" y="245" width="145" height="34" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="682" y="267" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Sharded (scalable)</text>

    <!-- Data Stores -->
    <text x="400" y="465" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11" font-weight="600" letter-spacing="0.1em">DATA LAYER</text>

    <rect x="100" y="480" width="150" height="40" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="175" y="505" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">PostgreSQL</text>

    <rect x="270" y="480" width="130" height="40" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="335" y="505" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">QuestDB (TSDB)</text>

    <rect x="420" y="480" width="110" height="40" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="475" y="505" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Redis</text>

    <rect x="550" y="480" width="140" height="40" rx="6" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="620" y="505" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Next.js Frontend</text>

    <!-- Connection lines from layers to data stores -->
    <line x1="175" y1="315" x2="175" y2="480" stroke="var(--color-border)" stroke-width="1" opacity="0.2"/>
    <line x1="335" y1="425" x2="335" y2="480" stroke="var(--color-border)" stroke-width="1" opacity="0.2"/>
    <line x1="475" y1="425" x2="475" y2="480" stroke="var(--color-border)" stroke-width="1" opacity="0.2"/>
  </svg>
</div>

<style>
  .diagram-container {
    max-width: 50rem;
    margin: var(--space-8) auto;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-primary);
  }

  .diagram-container svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .diagram-container svg text {
    font-family: 'DM Sans', ui-sans-serif, system-ui, sans-serif;
  }
</style>
