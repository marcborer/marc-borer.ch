---
// Cloud Infrastructure: High-level topology showing On-Premises ↔ Hybrid Boundary ↔ Microsoft 365 Cloud
// Rows aligned so each on-prem node connects horizontally to its cloud counterpart
---

<div class="diagram-container" data-animate="slide-up">
  <svg viewBox="0 0 800 460" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Cloud Infrastructure Architecture Diagram">
    <!-- Background regions -->
    <rect x="20" y="40" width="220" height="380" rx="12" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="130" y="70" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11" font-weight="600" letter-spacing="0.1em">ON-PREMISES</text>

    <rect x="340" y="40" width="440" height="380" rx="12" fill="var(--color-bg-secondary)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="560" y="70" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11" font-weight="600" letter-spacing="0.1em">MICROSOFT 365 / AZURE</text>

    <!-- Hybrid boundary -->
    <line x1="280" y1="55" x2="280" y2="400" stroke="var(--color-accent)" stroke-width="2" stroke-dasharray="6 4" opacity="0.6"/>
    <text x="280" y="435" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">HYBRID BOUNDARY</text>

    <!-- Row 1 (y=110): AD → Identity & Access -->
    <rect x="45" y="95" width="170" height="48" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="130" y="124" text-anchor="middle" fill="var(--color-text-primary)" font-size="12" font-weight="500">Active Directory</text>

    <rect x="370" y="93" width="180" height="52" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="460" y="116" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">IDENTITY & ACCESS</text>
    <text x="460" y="133" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Entra ID · MFA · Graph API</text>

    <rect x="580" y="93" width="180" height="52" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="670" y="116" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">ENDPOINT MGMT</text>
    <text x="670" y="133" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Intune · BIOS · Compliance</text>

    <!-- Horizontal line: AD → Identity -->
    <line x1="215" y1="119" x2="370" y2="119" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4"/>

    <!-- Row 2 (y=200): SBC → Cloud & Messaging -->
    <rect x="45" y="185" width="170" height="48" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="130" y="214" text-anchor="middle" fill="var(--color-text-primary)" font-size="12" font-weight="500">SBC / Telephony</text>

    <rect x="370" y="183" width="180" height="52" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="460" y="206" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">CLOUD & MESSAGING</text>
    <text x="460" y="223" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Exchange · Teams · DR</text>

    <!-- Horizontal line: SBC → Messaging -->
    <line x1="215" y1="209" x2="370" y2="209" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4"/>

    <!-- Row 3 (y=290): Server Fleet → Security & SIEM -->
    <rect x="45" y="275" width="170" height="48" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-border)" stroke-width="1"/>
    <text x="130" y="304" text-anchor="middle" fill="var(--color-text-primary)" font-size="12" font-weight="500">Server Fleet</text>

    <rect x="370" y="273" width="180" height="52" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="460" y="296" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">SECURITY & SIEM</text>
    <text x="460" y="313" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">Elastic Stack · Alerting</text>

    <rect x="580" y="273" width="180" height="52" rx="8" fill="var(--color-bg-elevated)" stroke="var(--color-accent)" stroke-width="1.5"/>
    <text x="670" y="296" text-anchor="middle" fill="var(--color-accent)" font-size="10" font-weight="600">AUTOMATION</text>
    <text x="670" y="313" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">PowerShell · Azure · IaC</text>

    <!-- Horizontal line: Server Fleet → SIEM -->
    <line x1="215" y1="299" x2="370" y2="299" stroke="var(--color-accent)" stroke-width="1.5" opacity="0.4"/>

    <!-- Cloud internal connections (subtle vertical) -->
    <line x1="460" y1="145" x2="460" y2="183" stroke="var(--color-border)" stroke-width="1" opacity="0.3"/>
    <line x1="460" y1="235" x2="460" y2="273" stroke="var(--color-border)" stroke-width="1" opacity="0.3"/>
    <line x1="670" y1="145" x2="670" y2="273" stroke="var(--color-border)" stroke-width="1" opacity="0.2" stroke-dasharray="4 3"/>

    <!-- End Users -->
    <rect x="420" y="365" width="240" height="40" rx="8" fill="none" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4 3"/>
    <text x="540" y="390" text-anchor="middle" fill="var(--color-text-secondary)" font-size="11">End Users · Managed Devices</text>
  </svg>
</div>

<style>
  .diagram-container {
    max-width: 50rem;
    margin: var(--space-8) auto;
    padding: var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-bg-primary);
  }

  .diagram-container svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .diagram-container svg text {
    font-family: 'DM Sans', ui-sans-serif, system-ui, sans-serif;
  }
</style>
