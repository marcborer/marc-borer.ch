---
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

const lang = (Astro.currentLocale || 'de') as Lang;
const t = useTranslations(lang);
const isDE = lang === 'de';
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-links">
      <a href="mailto:mb@marc-borer.ch" class="footer-link" aria-label="Email">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="M22 4L12 13L2 4" />
        </svg>
        <span>Email</span>
      </a>
      <a href="https://github.com/marcborer" class="footer-link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        <span>GitHub</span>
      </a>
      <a href="https://linkedin.com/in/marc-b-6780ab5a/" class="footer-link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        <span>LinkedIn</span>
      </a>
    </div>
    <div class="footer-legal">
      <a href={isDE ? '/impressum' : '/en/legal-notice'} class="footer-legal-link">{t('footer.impressum')}</a>
      <span class="footer-legal-sep" aria-hidden="true">·</span>
      <a href={isDE ? '/datenschutz' : '/en/privacy'} class="footer-legal-link">{t('footer.privacy')}</a>
    </div>
    <p class="footer-copy">{t('footer.copyright')}</p>
  </div>
</footer>

<style>
  .footer {
    border-top: none;
    border-image: linear-gradient(to right, transparent, var(--color-accent-subtle), var(--color-accent), var(--color-accent-subtle), transparent) 1;
    border-image-width: 1px 0 0 0;
    border-style: solid;
    padding: var(--space-10) var(--space-6);
    margin-top: auto;
  }

  .footer-inner {
    max-width: 90rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .footer-links {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-accent);
  }

  .footer-legal {
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .footer-legal-link {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-legal-link:hover {
    color: var(--color-accent);
  }

  .footer-legal-sep {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    opacity: 0.5;
  }

  .footer-copy {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }
</style>
