---
import TechBadge from './TechBadge.astro';
import { getLangFromUrl, useTranslations, getLocalePath } from '../i18n/utils';

interface Props {
  title: string;
  description: string;
  tech: string[];
  link: string;
  repo?: string;
}

const { title, description, tech, link, repo } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<article class="card">
  <h3 class="card-title">{title}</h3>
  <p class="card-description">{description}</p>
  <div class="card-tech">
    {tech.map((t) => <TechBadge name={t} />)}
  </div>
  <div class="card-links">
    <a href={getLocalePath(link, lang)} class="card-link">
      {t('projects.viewProject')}
      <span aria-hidden="true">&rarr;</span>
    </a>
    {repo && (
      <a href={repo} class="card-link card-link--github" target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>
    )}
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    padding: var(--space-8);
    background-color: rgba(30, 41, 59, 0.75);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: transform 0.3s ease, box-shadow 0.3s ease, border-color 0.3s ease;
  }

  :global([data-theme="light"]) .card {
    background-color: rgba(255, 255, 255, 0.75);
  }

  @media (prefers-color-scheme: light) {
    :global(:root:not([data-theme])) .card {
      background-color: rgba(255, 255, 255, 0.75);
    }
  }

  @media (hover: hover) {
    .card:hover {
      transform: translateY(-4px) scale(1.01);
      box-shadow: 0 0 30px var(--color-accent-subtle);
      border-color: var(--color-accent);
    }
  }

  .card-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-3);
  }

  .card-description {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--space-6);
  }

  .card-tech {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .card-links {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-top: auto;
  }

  .card-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .card-link:hover {
    color: var(--color-accent-hover);
  }

  .card-link--github {
    color: var(--color-text-secondary);
  }

  .card-link--github:hover {
    color: var(--color-accent);
  }

  .card-link--github svg {
    display: inline-block;
  }
</style>
