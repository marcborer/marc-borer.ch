---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import DocSidebar from '../components/DocSidebar.astro';

interface NavChild {
  label: string;
  href: string;
}

interface NavItem {
  label: string;
  href?: string;
  children?: NavChild[];
}

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  sidebarTitle: string;
  sidebarItems: NavItem[];
}

const { title, description, ogImage, sidebarTitle, sidebarItems } = Astro.props;
---

<BaseLayout title={title} description={description} ogImage={ogImage}>
  <div class="page">
    <Nav />
    <div class="doc-container">
      <DocSidebar title={sidebarTitle} items={sidebarItems} />
      <main class="doc-content" id="main-content">
        <slot />
      </main>
    </div>
    <Footer />
  </div>
</BaseLayout>

<style>
  .page {
    display: flex;
    flex-direction: column;
    min-height: 100dvh;
  }

  .doc-container {
    flex: 1;
    display: grid;
    grid-template-columns: 250px 1fr;
    gap: var(--space-8);
    width: 100%;
    max-width: 90rem;
    margin: 0 auto;
    padding: var(--space-8) var(--space-6);
  }

  .doc-content {
    min-width: 0;
    max-width: 65rem;
  }

  /* ---- Prose styles for rendered markdown ---- */
  .doc-content :global(h1) {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-6);
  }

  .doc-content :global(h2) {
    font-size: var(--text-2xl);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .doc-content :global(h3) {
    font-size: var(--text-xl);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .doc-content :global(h4) {
    font-size: var(--text-lg);
    margin-top: var(--space-6);
    margin-bottom: var(--space-2);
  }

  .doc-content :global(p) {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-4);
  }

  .doc-content :global(ul),
  .doc-content :global(ol) {
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-4);
    padding-left: var(--space-6);
  }

  .doc-content :global(li) {
    margin-bottom: var(--space-2);
  }

  .doc-content :global(strong) {
    color: var(--color-text-heading);
    font-weight: 600;
  }

  .doc-content :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: var(--color-accent-subtle);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.2s ease;
  }

  .doc-content :global(a:hover) {
    text-decoration-color: var(--color-accent);
  }

  /* Code blocks */
  .doc-content :global(pre) {
    background-color: var(--slate-900);
    color: var(--slate-200);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    margin-bottom: var(--space-6);
    overflow-x: auto;
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  .doc-content :global(code) {
    font-family: 'SF Mono', 'Fira Code', 'Fira Mono', 'Roboto Mono', monospace;
    font-size: 0.9em;
  }

  .doc-content :global(:not(pre) > code) {
    background-color: var(--color-accent-subtle);
    color: var(--color-accent);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
  }

  /* Tables */
  .doc-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
    margin-bottom: var(--space-6);
    overflow-x: auto;
    display: block;
  }

  .doc-content :global(thead) {
    background-color: var(--color-bg-secondary);
  }

  .doc-content :global(th) {
    font-weight: 600;
    color: var(--color-text-heading);
    text-align: left;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
  }

  .doc-content :global(td) {
    color: var(--color-text-secondary);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
  }

  .doc-content :global(tr:hover td) {
    background-color: var(--color-accent-subtle);
  }

  /* Blockquotes */
  .doc-content :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-4);
    margin-bottom: var(--space-4);
    color: var(--color-text-secondary);
    font-style: italic;
  }

  /* Horizontal rules */
  .doc-content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--space-8) 0;
  }

  /* Mobile layout */
  @media (max-width: 768px) {
    .doc-container {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .doc-content {
      max-width: 100%;
    }
  }
</style>
