---
import HreflangLinks from '../components/HreflangLinks.astro';
import ScrollAnimations from '../components/ScrollAnimations.astro';
import CookieConsent from '../components/CookieConsent.astro';
import { useTranslations } from '../i18n/utils';
import type { Lang } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const lang = (Astro.currentLocale || 'de') as Lang;
const t = useTranslations(lang);

const defaultDescription = lang === 'de'
  ? 'Portfolio von Marc Borer — Senior ICT Systems Architect'
  : 'Portfolio of Marc Borer — Senior ICT Systems Architect';

const { title, description = defaultDescription, ogImage } = Astro.props;
const resolvedOgImage = ogImage
  ? `https://marc-borer.ch${ogImage}`
  : 'https://marc-borer.ch/og/default.png';
const canonicalUrl = Astro.url.href;
const isHomepage = Astro.url.pathname === '/' || Astro.url.pathname === '/en/' || Astro.url.pathname === '/en';

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Marc Borer",
  "jobTitle": "Senior ICT Systems Architect",
  "url": "https://marc-borer.ch",
  "sameAs": [
    "https://github.com/marcborer",
    "https://linkedin.com/in/marc-b-6780ab5a/"
  ],
  "knowsAbout": [
    "Enterprise Architecture",
    "Hybrid Cloud Infrastructure",
    "Identity & Access Management",
    "CI/CD Automation",
    "Security & Observability"
  ]
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Marc Borer — Senior ICT Systems Architect",
  "url": "https://marc-borer.ch"
};
---

<!doctype html>
<html lang={Astro.currentLocale || 'de'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={resolvedOgImage} />

    <title>{title}</title>

    <!-- Google Analytics (loaded only after consent) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      function loadGA() {
        if (document.querySelector('script[src*="googletagmanager"]')) return;
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=G-YDWCY6XBPN';
        document.head.appendChild(s);
        gtag('js', new Date());
        gtag('config', 'G-YDWCY6XBPN');
      }
      try {
        if (localStorage.getItem('cookie-consent') === 'accepted') loadGA();
      } catch(e) {}
    </script>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts (self-hosted) -->
    <link rel="preload" href="/fonts/dm-sans-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Global Styles -->
    <style is:global>
      @import '../styles/fonts.css';
      @import '../styles/global.css';
    </style>

    <!-- Theme Detection (inline to prevent FOUC) -->
    <script is:inline>
      (function () {
        var theme = null;
        try {
          theme = localStorage.getItem('theme');
        } catch (e) {}
        if (theme === 'light' || theme === 'dark') {
          document.documentElement.dataset.theme = theme;
        } else if (window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches) {
          document.documentElement.dataset.theme = 'light';
        } else {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>

    <link rel="canonical" href={canonicalUrl} />
    <HreflangLinks />
    {isHomepage && (
      <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    )}
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to main content</a>
    <slot />
    <ScrollAnimations />
    <CookieConsent />
  </body>
</html>
